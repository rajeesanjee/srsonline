generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  CUSTOMER
  STAFF
}

enum SalePriceMode {
  WHOLESALE
  RETAIL
  CARD
}

enum SaleStatus {
  OPEN
  HOLD
  COMPLETED
  CANCELLED
}

enum PaymentType {
  CASH
  CARD
  GPAY
  CREDIT
  MIXED
  OTHER
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(CUSTOMER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Customer {
  id String @id @default(cuid())

  customerCode String  @unique
  name         String
  nameTamil    String?

  phone   String?
  address String?
  area    String?

  openingBalance Decimal @default(0) @db.Decimal(12, 2)
  balance        Decimal @default(0) @db.Decimal(12, 2)
  creditLimit    Decimal @default(0) @db.Decimal(12, 2)

  rewardPoints Decimal @default(0) @db.Decimal(12, 2)

  lastVisitDate DateTime?

  isActive Boolean @default(true)

  sales Sale[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([phone])
  @@index([area])
  @@index([balance])
  @@index([lastVisitDate])
}

model Supplier {
  id String @id @default(cuid())

  supplierCode String @unique
  name         String

  phone          String?
  address        String?
  contactDetails String?
  gstin          String?

  openingBalance Decimal @default(0) @db.Decimal(12, 2)
  balance        Decimal @default(0) @db.Decimal(12, 2)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([phone])
  @@index([gstin])
  @@index([balance])
}

model Product {
  id String @id @default(cuid())

  productCode String? @unique
  barcode     String? @unique

  name      String
  nameTamil String?

  category String
  unit     String @default("PCS")

  purchasePrice Decimal @default(0) @db.Decimal(10, 2)
  mrp           Decimal @default(0) @db.Decimal(10, 2)

  wholesalePrice Decimal? @db.Decimal(10, 2)
  retailPrice    Decimal  @default(0) @map("price") @db.Decimal(10, 2)
  cardPrice      Decimal? @map("creditPrice") @db.Decimal(10, 2)

  wholesaleProfitPercent Decimal? @db.Decimal(8, 2)
  retailProfitPercent    Decimal? @map("profitPercent") @db.Decimal(8, 2)
  cardProfitPercent      Decimal? @db.Decimal(8, 2)

  gstRate Decimal @default(0) @db.Decimal(5, 2)
  hsnCode String?

  stock        Decimal @default(0) @db.Decimal(12, 3)
  allowDecimal Boolean @default(false)

  supplierName String?
  counter      Int     @default(0)

  discountPercent Decimal? @db.Decimal(8, 2)

  saleItems SaleItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Sale {
  id String @id @default(cuid())

  billNumber String   @unique
  billDate   DateTime @default(now())

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  customerCode String?
  customerName String  @default("CASH")

  previousBalance Decimal @default(0) @db.Decimal(12, 2)
  receivedAmount  Decimal @default(0) @db.Decimal(12, 2)
  closingBalance  Decimal @default(0) @db.Decimal(12, 2)

  priceMode SalePriceMode @default(RETAIL)

  itemCount Decimal @default(0) @db.Decimal(12, 3)

  subtotal Decimal @default(0) @db.Decimal(12, 2)
  gstTotal Decimal @default(0) @db.Decimal(12, 2)
  discount Decimal @default(0) @db.Decimal(12, 2)
  roundOff Decimal @default(0) @db.Decimal(12, 2)
  total    Decimal @default(0) @db.Decimal(12, 2)

  paymentType PaymentType @default(CASH)

  cashAmount   Decimal @default(0) @db.Decimal(12, 2)
  cardAmount   Decimal @default(0) @db.Decimal(12, 2)
  gpayAmount   Decimal @default(0) @db.Decimal(12, 2)
  creditAmount Decimal @default(0) @db.Decimal(12, 2)
  otherAmount  Decimal @default(0) @db.Decimal(12, 2)

  status SaleStatus @default(OPEN)

  items SaleItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([billDate])
  @@index([customerId])
  @@index([customerName])
  @@index([status])
}

model SaleItem {
  id String @id @default(cuid())

  saleId String
  sale   Sale   @relation(fields: [saleId], references: [id], onDelete: Cascade)

  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  productCode String?
  barcode     String?

  productName      String
  productNameTamil String?

  counter Int @default(0)

  quantity Decimal @db.Decimal(12, 3)

  mrp  Decimal @default(0) @db.Decimal(10, 2)
  rate Decimal @db.Decimal(10, 2)

  gstRate   Decimal @default(0) @db.Decimal(5, 2)
  gstAmount Decimal @default(0) @db.Decimal(12, 2)

  discountPercent Decimal @default(0) @db.Decimal(8, 2)
  discountAmount  Decimal @default(0) @db.Decimal(12, 2)

  amount Decimal @db.Decimal(12, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([saleId])
  @@index([productId])
  @@index([productCode])
  @@index([counter])
}
